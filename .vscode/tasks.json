{
  "version": "2.0.0",
  "options": {
    "env": {
      "PATH": "${env:USERPROFILE}\\scoop\\shims;${env:USERPROFILE}\\scoop\\apps\\mingw\\current\\bin;${env:PATH}"
    }
  },
  "tasks": [
    {
      "label": "env: cek toolchain",
      "type": "shell",
      "command": "where.exe",
      "args": [
        "cmake"
      ],
      "problemMatcher": []
    },
    {
      "label": "configure: msvc-debug",
      "type": "shell",
      "command": "cmake",
      "args": [
        "-S",
        ".",
        "-B",
        "build/msvc-debug",
        "-G",
        "Visual Studio 17 2022",
        "-A",
        "x64"
      ],
      "problemMatcher": "$msCompile"
    },
    {
      "label": "build: msvc-debug",
      "type": "shell",
      "command": "cmake",
      "args": [
        "--build",
        "build/msvc-debug",
        "--config",
        "Debug"
      ],
      "dependsOn": [
        "configure: msvc-debug"
      ],
      "problemMatcher": "$msCompile"
    },
    {
      "label": "run: msvc-debug",
      "type": "shell",
      "command": "${workspaceFolder}/build/msvc-debug/Debug/saka-note.exe",
      "dependsOn": [
        "build: msvc-debug"
      ],
      "problemMatcher": []
    },
    {
      "label": "configure: mingw-debug",
      "type": "shell",
      "command": "cmake",
      "args": [
        "-S",
        ".",
        "-B",
        "build/mingw-debug",
        "-G",
        "MinGW Makefiles",
        "-DCMAKE_BUILD_TYPE=Debug"
      ],
      "problemMatcher": "$gcc"
    },
    {
      "label": "stop: saka-note",
      "type": "shell",
      "command": "$targets = @('saka-note', 'legacy-notepad'); foreach ($t in $targets) { Get-Process $t -ErrorAction SilentlyContinue | Stop-Process -Force }; exit 0",
      "problemMatcher": []
    },
    {
      "label": "build: mingw-debug",
      "type": "shell",
      "command": "cmake",
      "args": [
        "--build",
        "build/mingw-debug"
      ],
      "dependsOn": [
        "stop: saka-note",
        "configure: mingw-debug"
      ],
      "dependsOrder": "sequence",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": "$gcc"
    },
    {
      "label": "run: mingw-debug",
      "type": "shell",
      "command": "${workspaceFolder}/build/mingw-debug/saka-note.exe",
      "dependsOn": [
        "build: mingw-debug"
      ],
      "problemMatcher": []
    },
    {
      "label": "benchmark: saka-note-ci-gate",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-Command",
        "& \"${workspaceFolder}/build/mingw-debug/saka-note.exe\" --benchmark-ci"
      ],
      "dependsOn": [
        "build: mingw-debug"
      ],
      "problemMatcher": []
    },
    {
      "label": "benchmark: compare-notepad (quick)",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}/tools/compare-notepad.ps1",
        "-Iterations",
        "1",
        "-SampleSeconds",
        "6",
        "-SampleIntervalMs",
        "500",
        "-WarmupMs",
        "2500",
        "-ForceCloseBeforeEachRun",
        "-SkipLegacyInternalGate"
      ],
      "dependsOn": [
        "build: mingw-debug"
      ],
      "problemMatcher": []
    },
    {
      "label": "benchmark: compare-notepad (full)",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}/tools/compare-notepad.ps1",
        "-Iterations",
        "3",
        "-SampleSeconds",
        "8",
        "-SampleIntervalMs",
        "500",
        "-WarmupMs",
        "3000",
        "-ForceCloseBeforeEachRun"
      ],
      "dependsOn": [
        "build: mingw-debug"
      ],
      "problemMatcher": []
    },
    {
      "label": "maintenance: cleanup perf-runs",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}/tools/cleanup-perf-runs.ps1",
        "-KeepLatest",
        "2"
      ],
      "problemMatcher": []
    }
  ]
}
